  "item": [
    {
      "name": "Auth",
      "description": "Login mutation + Me query. Login sets `sid_b2b` cookie which must be present on every authenticated request.",
      "item": [
        {
          "name": "Positive",
          "item": [
            {
              "name": "Login",
              "event": [{
                "listen": "test",
                "script": {"type":"text/javascript","exec":[
                  "pm.test('login.errors is null', () => pm.expect(pm.response.json().data.login.errors).to.be.null);",
                  "pm.test('user.id present', () => pm.expect(pm.response.json().data.login.user.id).to.be.a('string'));",
                  "const cookie = pm.cookies.get('sid_b2b');",
                  "if (cookie) pm.collectionVariables.set('sid_b2b', cookie);"
                ]}
              }],
              "request": {"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\n  \"operationName\": \"Login\",\n  \"query\": \"mutation Login($usernameOrEmail: String!, $password: String!, $companyId: String!) { login(usernameOrEmail: $usernameOrEmail, password: $password, companyId: $companyId) { user { id email name role } errors { field message } } }\",\n  \"variables\": {\n    \"usernameOrEmail\": \"{{emailWeb}}\",\n    \"password\": \"{{passwordWeb}}\",\n    \"companyId\": \"{{companyId}}\"\n  }\n}"},"url":{"raw":"{{url}}","host":["{{url}}"]}}
            },
            {
              "name": "Me",
              "request": {"method":"POST","header":[{"key":"Content-Type","value":"application/json"},{"key":"Cookie","value":"sid_b2b={{sid_b2b}}"}],"body":{"mode":"raw","raw":"{\n  \"operationName\": \"Me\",\n  \"query\": \"query Me { me { id email name role status } }\"\n}"},"url":{"raw":"{{url}}","host":["{{url}}"]}}
            }
          ]
        },
        {
          "name": "Negative",
          "item": [
            {
              "name": "[NEG] Login - wrong password",
              "event":[{"listen":"test","script":{"type":"text/javascript","exec":[
                "pm.test('user is null or errors present', () => {",
                "  const j = pm.response.json();",
                "  const userNull = j.data && j.data.login && j.data.login.user === null;",
                "  const hasErrors = j.errors !== undefined;",
                "  pm.expect(userNull || hasErrors).to.be.true;",
                "});"]}}],
              "request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"operationName\":\"Login\",\"query\":\"mutation Login($u:String!,$p:String!,$c:String!){login(usernameOrEmail:$u,password:$p,companyId:$c){user{id} errors{message}}}\",\"variables\":{\"u\":\"{{emailWeb}}\",\"p\":\"wrong-password\",\"c\":\"{{companyId}}\"}}"},"url":{"raw":"{{url}}","host":["{{url}}"]}}
            },
            {
              "name": "[NEG] Login - wrong companyId",
              "request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"operationName\":\"Login\",\"query\":\"mutation Login($u:String!,$p:String!,$c:String!){login(usernameOrEmail:$u,password:$p,companyId:$c){user{id} errors{message}}}\",\"variables\":{\"u\":\"{{emailWeb}}\",\"p\":\"{{passwordWeb}}\",\"c\":\"{{nonExistentUuid}}\"}}"},"url":{"raw":"{{url}}","host":["{{url}}"]}}
            },
            {
              "name": "[NEG] Me - no session cookie",
              "event":[{"listen":"test","script":{"type":"text/javascript","exec":[
                "pm.test('errors present', () => pm.expect(pm.response.json().errors).to.not.be.undefined);",
                "pm.test('not authenticated', () => pm.expect(pm.response.text()).to.include('not authenticated'));"]}}],
              "request":{"method":"POST","header":[{"key":"Content-Type","value":"application/json"}],"body":{"mode":"raw","raw":"{\"operationName\":\"Me\",\"query\":\"query Me { me { id email } }\"}"},"url":{"raw":"{{url}}","host":["{{url}}"]}}
            }
          ]
        }
